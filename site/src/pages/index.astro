---
import ReviewLayout from '../layouts/ReviewLayout.astro';
const base = import.meta.env.BASE_URL;

const modules = [
  { id: 'M1',  slug: 'm1-comprendre-llm',           niveau: 'N1', titre: "Comprendre l'IA Générative",       duree: '~20 min', statut: '✅ Prêt' },
  { id: 'M2',  slug: 'm2-risques-gouvernance',       niveau: 'N1', titre: 'Risques & gouvernance de l\'IA',   duree: '~20 min', statut: '✅ Prêt' },
  { id: 'M3',  slug: 'm3-baseline-n1',              niveau: 'N1', titre: 'Évaluation de base Niveau 1',      duree: 'Checklist', statut: '✅ Prêt' },
  { id: 'M4',  slug: 'm4-4types-prompts',           niveau: 'N2', titre: 'Les 4 types de prompts',           duree: '~20 min', statut: '✅ Prêt' },
  { id: 'M5',  slug: 'm5-methode-niveaux',          niveau: 'N2', titre: 'La méthode par niveaux',           duree: '~20 min', statut: '✅ Prêt' },
  { id: 'M6',  slug: 'm6-connaissance-capitalisee', niveau: 'N2', titre: 'Capitaliser sa connaissance',      duree: '~20 min', statut: '✅ Prêt' },
  { id: 'M7',  slug: 'm7-baseline-n2',              niveau: 'N2', titre: 'Évaluation de base Niveau 2',      duree: 'Atelier', statut: '✅ Prêt' },
  { id: 'M8',  slug: 'm8-assistant-personnalise',   niveau: 'N3', titre: 'Créer son assistant personnalisé', duree: '~20 min', statut: '✅ Prêt' },
  { id: 'M9',  slug: 'm9-skills-bases-connaissance',niveau: 'N3', titre: 'Projets & bases de connaissance',  duree: '~20 min', statut: '✅ Prêt' },
  { id: 'M10', slug: 'm10-intro-mcp',               niveau: 'N3', titre: 'Connecter l\'IA à vos outils',    duree: '~20 min', statut: '⏳ Conditionnel' },
  { id: 'M11', slug: 'm11-baseline-n3',             niveau: 'N3', titre: 'Gouverner un dispositif IA',       duree: 'Guide', statut: '✅ Prêt' },
];
---
<ReviewLayout title="Review — Accueil">
  <style>
    .review-home h1 { font-size: 1.6rem; margin-bottom: 0.3rem; }
    .review-home .subtitle { color: #666; margin-bottom: 2rem; font-size: 0.95rem; }
    .review-home .note-box {
      background: #fffbea;
      border: 1px solid #fcd34d;
      border-radius: 6px;
      padding: 0.85rem 1rem;
      font-size: 0.88rem;
      margin-bottom: 1.75rem;
      color: #78350f;
    }
    .review-home .note-box code { background: #fef3c7; padding: 1px 4px; border-radius: 3px; font-size: 0.85em; }

    .review-table { width: 100%; border-collapse: collapse; font-size: 0.9rem; margin-bottom: 2rem; }
    .review-table th { background: #f5f5f5; font-weight: 700; padding: 0.5rem 0.75rem; border: 1px solid #e0e0e0; text-align: left; }
    .review-table td { padding: 0.45rem 0.75rem; border: 1px solid #e0e0e0; vertical-align: middle; }
    .review-table tr:hover td { background: #fafafa; }
    .review-table a { color: #1a1a1a; font-weight: 500; text-decoration: none; }
    .review-table a:hover { text-decoration: underline; color: #0070f3; }

    .badge { display: inline-block; font-size: 0.7rem; font-weight: 700; padding: 2px 6px; border-radius: 3px; }
    .n1 { background: #dcfce7; color: #166534; }
    .n2 { background: #fef9c3; color: #713f12; }
    .n3 { background: #ede9fe; color: #4c1d95; }

    .suivi-section h2 { font-size: 1rem; font-weight: 700; margin-bottom: 1rem; }
    .suivi-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 0.5rem; }
    .suivi-item { display: flex; align-items: center; gap: 0.5rem; padding: 0.5rem 0.75rem; border: 1px solid #e5e5e5; border-radius: 5px; font-size: 0.85rem; }
    .suivi-item input { cursor: pointer; }
    .suivi-item label { cursor: pointer; user-select: none; }
  </style>

  <div class="review-home">
    <h1>🔍 Review Formation IA PME — Relecture orale</h1>
    <p class="subtitle">Session de validation avant tournage — 2026-03-17</p>

    <div class="note-box">
      📋 Notes de relecture : <code>_qualite/notes-relecture-orale.md</code> — noter les passages à retravailler, durées réelles, points d'accroche.
    </div>

    <table class="review-table">
      <thead>
        <tr>
          <th>Module</th>
          <th>Niveau</th>
          <th>Durée cible</th>
          <th>Statut</th>
        </tr>
      </thead>
      <tbody>
        {modules.map(m => (
          <tr>
            <td><a href={`${base}modules/${m.slug}/`}>{m.id} — {m.titre}</a></td>
            <td><span class={`badge ${m.niveau.toLowerCase()}`}>{m.niveau}</span></td>
            <td>{m.duree}</td>
            <td>{m.statut}</td>
          </tr>
        ))}
      </tbody>
    </table>

    <div class="suivi-section">
      <h2>Suivi relecture orale</h2>
      <div class="suivi-grid">
        {modules.map(m => (
          <div class="suivi-item">
            <input type="checkbox" id={`check-${m.id.toLowerCase()}`} />
            <label for={`check-${m.id.toLowerCase()}`}>{m.id} — {m.titre.slice(0, 22)}{m.titre.length > 22 ? '…' : ''}</label>
          </div>
        ))}
      </div>
    </div>
  </div>
</ReviewLayout>
