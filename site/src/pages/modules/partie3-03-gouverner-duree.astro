---
import ReviewLayout from '../../layouts/ReviewLayout.astro';
import ModuleTabs from '../../components/ModuleTabs.astro';
import { readMarkdownFile, toHtml } from '../../lib/modules';

const dir = 'Partie3/03-gouverner-duree';
const sections = [
  { id: 'guide',    label: 'Guide',        html: toHtml(readMarkdownFile(`${dir}/guide-v5.md`)) },
  { id: 'quiz',     label: 'Quiz',         html: toHtml(readMarkdownFile(`${dir}/quiz.md`)) },
  { id: 'exercice', label: 'Exercice',     html: toHtml(readMarkdownFile(`${dir}/exercice.md`)) },
  { id: 'post',     label: 'Post LinkedIn',html: toHtml(readMarkdownFile(`${dir}/post-linkedin.md`)) },
];
---
<ReviewLayout title="Gouverner dans la durée">
  <ModuleTabs module="Partie 3 — bloc 3" titre="Gouverner dans la durée" sections={sections} />
</ReviewLayout>
