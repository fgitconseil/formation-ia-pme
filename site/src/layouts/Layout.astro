---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}
const { title, description = "Formation IA Générative gratuite pour les professionnels. Méthode S.F.O.I. — Structurer, Fiabiliser, Optimiser, Industrialiser." } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/x-icon" href={`${base}favicon.ico`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title} · Formation IA — FGIT Conseil</title>

    <!-- Fonts — Inter, same as fgitconseil.com -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />

    <style is:global>
      /* ── Design tokens — alignés avec fgitconseil.com design-system.css ── */
      :root {
        --primary-600: #2563eb;
        --primary-700: #1d4ed8;
        --primary-500: #3b82f6;
        --accent-500:  #8b5cf6;
        --accent-600:  #7c3aed;
        --slate-900:   #0f172a;
        --slate-800:   #1e293b;

        /* S.F.O.I. palette */
        --sfoi-s: #22c55e;
        --sfoi-f: #eab308;
        --sfoi-o: #3b82f6;
        --sfoi-i: #a855f7;
      }

      body { font-family: 'Inter', sans-serif; }

      .gradient-text {
        background: linear-gradient(135deg, var(--primary-600), var(--accent-500));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      /* Buttons — alignés avec design-system.css de fgitconseil.com */
      .btn-primary {
        background: linear-gradient(135deg, var(--primary-600), var(--primary-700));
        color: white;
        padding: 0.75rem 1.5rem;
        border-radius: 0.5rem;
        font-weight: 600;
        font-size: 0.875rem;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        box-shadow: 0 4px 6px rgba(37,99,235,0.2);
        transition: all 0.3s ease;
        border: none;
        cursor: pointer;
      }
      .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 12px rgba(37,99,235,0.3);
      }

      .btn-secondary {
        background: transparent;
        color: var(--primary-600);
        border: 2px solid var(--primary-600);
        padding: 0.75rem 1.5rem;
        border-radius: 0.5rem;
        font-weight: 600;
        font-size: 0.875rem;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.3s ease;
        cursor: pointer;
      }
      .btn-secondary:hover {
        background: var(--primary-600);
        color: white;
        transform: translateY(-2px);
      }

      /* Card — aligné avec design-system.css */
      .card {
        background: white;
        border-radius: 1rem;
        padding: 2rem;
        box-shadow: 0 4px 6px rgba(0,0,0,0.05);
        transition: all 0.3s ease;
        border: 1px solid #f1f5f9;
      }
      .card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 24px rgba(0,0,0,0.1);
        border-color: var(--primary-600);
      }

      /* SlidePlayer */
      .slide-player {
        background: white;
        border-radius: 1.25rem;
        overflow: hidden;
        box-shadow: 0 20px 40px rgba(0,0,0,0.12);
      }
      .progress-bar {
        height: 3px;
        background: linear-gradient(90deg, var(--primary-600), var(--accent-500));
        transition: width 0.4s ease;
      }
      .quiz-option {
        border: 2px solid #e2e8f0;
        border-radius: 0.75rem;
        padding: 0.875rem 1.25rem;
        cursor: pointer;
        transition: all 0.2s;
        background: white;
        text-align: left;
        width: 100%;
        font-size: 0.9rem;
        color: #334155;
      }
      .quiz-option:hover  { border-color: var(--primary-600); background: #eff6ff; }
      .quiz-option.correct { border-color: #22c55e; background: #f0fdf4; color: #15803d; }
      .quiz-option.wrong   { border-color: #ef4444; background: #fef2f2; color: #dc2626; }

      /* ── Header — aligné avec shared/components/header.js ── */
      .site-header {
        background: rgba(255,255,255,0.95);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid #e2e8f0;
        position: sticky;
        top: 0;
        z-index: 100;
      }
      .site-header .header-inner {
        max-width: 1280px;
        margin: 0 auto;
        padding: 0 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 4rem; /* h-16 = 64px */
      }
      .site-header .logo-link {
        display: flex;
        align-items: center;
        gap: 0.625rem;
        text-decoration: none;
        flex-shrink: 0;
      }
      .site-header .logo-img {
        height: 2.5rem; /* h-10 */
        width: auto;
      }
      .site-header .logo-badge {
        background: linear-gradient(135deg, var(--primary-600), var(--accent-600));
        color: white;
        font-size: 0.65rem;
        font-weight: 700;
        padding: 0.2rem 0.5rem;
        border-radius: 0.375rem;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }
      .site-header nav {
        position: static;
        background: none;
        border: none;
        backdrop-filter: none;
      }
      .site-header .nav-list {
        display: flex;
        align-items: center;
        gap: 0.25rem;
        list-style: none;
        margin: 0;
        padding: 0;
      }
      .site-header .nav-link {
        color: #475569;
        font-size: 0.875rem;
        font-weight: 500;
        text-decoration: none;
        padding: 0.375rem 0.75rem;
        border-radius: 0.375rem;
        transition: color 0.2s, background 0.2s;
      }
      .site-header .nav-link:hover { color: #0f172a; background: #f1f5f9; }
      .site-header .nav-cta {
        background: linear-gradient(135deg, var(--primary-600), var(--primary-700));
        color: white;
        font-size: 0.8rem;
        font-weight: 600;
        padding: 0.4rem 1rem;
        border-radius: 0.5rem;
        text-decoration: none;
        transition: all 0.2s;
        margin-left: 0.5rem;
      }
      .site-header .nav-cta:hover { background: linear-gradient(135deg, var(--primary-700), var(--accent-600)); transform: translateY(-1px); }
      .site-header .nav-cross {
        background: linear-gradient(135deg, var(--accent-600), var(--primary-600));
        color: white;
        font-size: 0.75rem;
        font-weight: 600;
        padding: 0.35rem 0.875rem;
        border-radius: 0.375rem;
        text-decoration: none;
        transition: all 0.2s;
        margin-left: 0.25rem;
      }
      .site-header .nav-cross:hover { opacity: 0.9; transform: translateY(-1px); }
      @media (max-width: 767px) {
        .site-header .nav-desktop { display: none; }
      }

      /* ── Footer — aligné avec shared/components/footer.js ── */
      .site-footer {
        background: #0f172a; /* slate-900 */
        color: white;
      }
      .site-footer .footer-inner {
        max-width: 1280px;
        margin: 0 auto;
        padding: 3rem 1.5rem;
      }
      .site-footer .footer-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 2rem;
      }
      @media (min-width: 768px) {
        .site-footer .footer-grid { grid-template-columns: 1fr 1fr 1fr; }
      }
      .site-footer .footer-logo-row {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 1rem;
      }
      .site-footer .footer-logo-img {
        height: 2rem;
        width: auto;
        opacity: 0.85;
      }
      .site-footer .footer-logo-text {
        font-size: 1.1rem;
        font-weight: 700;
        color: white;
      }
      .site-footer .footer-desc {
        color: #94a3b8;
        font-size: 0.875rem;
        line-height: 1.6;
        margin-bottom: 1rem;
        max-width: 20rem;
      }
      .site-footer .footer-legal {
        color: #64748b;
        font-size: 0.75rem;
        line-height: 1.7;
      }
      .site-footer .footer-heading {
        font-size: 0.875rem;
        font-weight: 600;
        color: white;
        margin-bottom: 0.875rem;
      }
      .site-footer .footer-links {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
      }
      .site-footer .footer-links a {
        color: #94a3b8;
        text-decoration: none;
        font-size: 0.875rem;
        transition: color 0.2s;
      }
      .site-footer .footer-links a:hover { color: #60a5fa; }
      .site-footer .footer-bottom {
        border-top: 1px solid #1e293b;
        margin-top: 2.5rem;
        padding-top: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        align-items: center;
        text-align: center;
      }
      @media (min-width: 768px) {
        .site-footer .footer-bottom {
          flex-direction: row;
          justify-content: space-between;
          text-align: left;
        }
      }
      .site-footer .footer-bottom p { color: #475569; font-size: 0.8rem; margin: 0; }
      .site-footer .footer-bottom a { color: #60a5fa; text-decoration: none; font-size: 0.8rem; }
      .site-footer .footer-bottom a:hover { text-decoration: underline; }

      /* ── Animations (remplace AOS) ── */
      @keyframes fadeUp {
        from { opacity: 0; transform: translateY(16px); }
        to   { opacity: 1; transform: translateY(0); }
      }
      .animate-fade-up   { animation: fadeUp 0.6s ease both; }
      .animate-fade-up-1 { animation-delay: 0.1s; }
      .animate-fade-up-2 { animation-delay: 0.2s; }
      .animate-fade-up-3 { animation-delay: 0.3s; }
      .animate-fade-up-4 { animation-delay: 0.4s; }
    </style>
  </head>

  <body class="bg-white text-slate-900">

    <!-- ── Header — même structure que fgitconseil.com ── -->
    <header class="site-header">
      <div class="header-inner">

        <!-- Logo -->
        <a href={base} class="logo-link">
          <img
            src={`${base}fgitlogotransp.png`}
            alt="FGIT Conseil"
            class="logo-img"
            width="160"
            height="40"
          />
          <span class="logo-badge">Formation IA</span>
        </a>

        <!-- Desktop nav -->
        <nav aria-label="Navigation principale">
          <ul class="nav-list nav-desktop">
            <li><a href={`${base}#syllabus`} class="nav-link">Parcours</a></li>
            <li><a href={`${base}#methode`}  class="nav-link">Méthode</a></li>
            <li>
              <a
                href="https://fgitconseil.com"
                target="_blank"
                rel="noopener"
                class="nav-cross"
              >Corporate ↗</a>
            </li>
            <li>
              <a href={`${base}formation/`} class="nav-cta">Commencer →</a>
            </li>
          </ul>
        </nav>

      </div>
    </header>

    <main>
      <slot />
    </main>

    <!-- ── Footer — même structure que fgitconseil.com ── -->
    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-grid">

          <!-- Colonne 1 : logo + info société -->
          <div>
            <div class="footer-logo-row">
              <img
                src={`${base}fgitlogotransp.png`}
                alt="FGIT Conseil"
                class="footer-logo-img"
                width="120"
                height="30"
              />
              <span class="footer-logo-text">FGIT Conseil</span>
            </div>
            <p class="footer-desc">
              Formation IA Générative gratuite pour les professionnels des PME/ETI françaises.
              Méthode S.F.O.I. — opérationnelle dès le premier bloc.
            </p>
            <div class="footer-legal">
              <p>FGIT Conseil SARL</p>
              <p>RCS Nanterre 527 571 798 · APE 6202A</p>
            </div>
          </div>

          <!-- Colonne 2 : Formation -->
          <div>
            <p class="footer-heading">Formation</p>
            <ul class="footer-links">
              <li><a href={`${base}formation/`}>Accéder au parcours</a></li>
              <li><a href={`${base}#syllabus`}>Programme</a></li>
              <li><a href={`${base}#methode`}>Méthode S.F.O.I.</a></li>
            </ul>
          </div>

          <!-- Colonne 3 : Ecosystem FGIT -->
          <div>
            <p class="footer-heading">Ecosystem FGIT Conseil</p>
            <ul class="footer-links">
              <li>
                <a href="https://fgitconseil.com" target="_blank" rel="noopener">
                  fgitconseil.com — Corporate
                </a>
              </li>
              <li>
                <a href="https://labs.fgitconseil.com" target="_blank" rel="noopener">
                  labs.fgitconseil.com — Innovation Lab
                </a>
              </li>
              <li>
                <a
                  href="https://www.linkedin.com/company/fgit-conseil"
                  target="_blank"
                  rel="noopener"
                >
                  LinkedIn
                </a>
              </li>
            </ul>
          </div>

        </div>

        <!-- Bottom bar -->
        <div class="footer-bottom">
          <p>© {new Date().getFullYear()} FGIT Conseil — Formation gratuite</p>
        </div>
      </div>
    </footer>

  </body>
</html>
