---
interface Section {
  id: string;
  label: string;
  html: string;
}
interface Props {
  module: string;
  titre: string;
  niveau?: string;
  sections: Section[];
  conditional?: boolean;
}
const { module, titre, niveau = '', sections, conditional = false } = Astro.props;

const niveauColors: Record<string, string> = {
  n1: '#dcfce7 / #166534',
  n2: '#fef9c3 / #713f12',
  n3: '#ede9fe / #4c1d95',
};
---

<div class="module-tabs" data-tabs>
  <div class="module-head">
    <div class="module-head-badges">
      {niveau && <span class={`badge niveau-${niveau.toLowerCase()}`}>{niveau}</span>}
      {conditional && <span class="badge badge-conditional">⏳ CONDITIONNEL</span>}
    </div>
    <h1>{module} — {titre}</h1>
  </div>

  <div class="tab-bar" role="tablist">
    {sections.map((section, i) => (
      <button
        class:list={['tab-btn', { active: i === 0 }]}
        data-tab={section.id}
        role="tab"
        type="button"
        aria-selected={i === 0 ? 'true' : 'false'}
      >
        {section.label}
      </button>
    ))}
  </div>

  {sections.map((section, i) => (
    <div
      class:list={['tab-panel', { 'is-hidden': i !== 0 }]}
      data-panel={section.id}
      role="tabpanel"
    >
      <div class="md-content" set:html={section.html} />
    </div>
  ))}
</div>

<script is:inline>
  document.querySelectorAll('[data-tabs]').forEach(function(container) {
    container.querySelectorAll('[data-tab]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var id = btn.getAttribute('data-tab');
        container.querySelectorAll('[data-tab]').forEach(function(b) {
          var isActive = b.getAttribute('data-tab') === id;
          b.classList.toggle('active', isActive);
          b.setAttribute('aria-selected', isActive ? 'true' : 'false');
        });
        container.querySelectorAll('[data-panel]').forEach(function(p) {
          p.classList.toggle('is-hidden', p.getAttribute('data-panel') !== id);
        });
      });
    });
  });
</script>

<style>
  .module-head {
    padding-bottom: 1.25rem;
    margin-bottom: 1.25rem;
    border-bottom: 1px solid #e5e5e5;
  }
  .module-head-badges {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }
  .module-head h1 {
    font-size: 1.6rem;
    font-weight: 700;
  }

  .badge {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 700;
    padding: 3px 8px;
    border-radius: 4px;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }
  .niveau-n1 { background: #dcfce7; color: #166534; }
  .niveau-n2 { background: #fef9c3; color: #713f12; }
  .niveau-n3 { background: #ede9fe; color: #4c1d95; }
  .badge-conditional { background: #fff3cd; color: #856404; border: 1px solid #ffc107; }

  .tab-bar {
    display: flex;
    gap: 0;
    border-bottom: 2px solid #e5e5e5;
    margin-bottom: 1.5rem;
  }
  .tab-btn {
    padding: 0.55rem 1.2rem;
    border: none;
    border-bottom: 2px solid transparent;
    margin-bottom: -2px;
    background: transparent;
    color: #666;
    font-size: 0.9rem;
    font-weight: 500;
    cursor: pointer;
    transition: color 0.15s, background 0.15s, border-color 0.15s;
    border-radius: 4px 4px 0 0;
  }
  .tab-btn:hover { color: #1a1a1a; background: #f5f5f5; }
  .tab-btn.active {
    color: #fff;
    background: #1a1a1a;
    border-bottom-color: #1a1a1a;
  }

  .is-hidden { display: none; }

  /* Markdown content styles */
  .md-content { line-height: 1.7; }
  .md-content h1 { font-size: 1.5rem; margin: 1.5rem 0 0.75rem; padding-bottom: 0.4rem; border-bottom: 1px solid #eee; }
  .md-content h2 { font-size: 1.25rem; margin: 1.5rem 0 0.6rem; }
  .md-content h3 { font-size: 1.05rem; margin: 1.25rem 0 0.5rem; }
  .md-content h4 { font-size: 0.95rem; margin: 1rem 0 0.4rem; font-weight: 700; color: #333; }
  .md-content p { margin-bottom: 0.9rem; }
  .md-content ul, .md-content ol { margin: 0.5rem 0 0.9rem 1.5rem; }
  .md-content li { margin-bottom: 0.25rem; }
  .md-content li > ul, .md-content li > ol { margin-top: 0.25rem; margin-bottom: 0.25rem; }
  .md-content strong { font-weight: 700; }
  .md-content em { font-style: italic; }
  .md-content hr { border: none; border-top: 1px solid #e5e5e5; margin: 1.5rem 0; }
  .md-content code {
    font-family: 'Courier New', Courier, monospace;
    font-size: 0.85em;
    background: #f3f3f3;
    padding: 1px 5px;
    border-radius: 3px;
    color: #c7254e;
  }
  .md-content pre {
    background: #f6f8fa;
    border: 1px solid #e5e5e5;
    border-radius: 6px;
    padding: 1rem 1.25rem;
    overflow-x: auto;
    margin: 0.75rem 0 1rem;
    font-size: 0.85rem;
    line-height: 1.5;
  }
  .md-content pre code {
    background: none;
    padding: 0;
    color: #1a1a1a;
    font-size: inherit;
  }
  .md-content blockquote {
    border-left: 3px solid #ccc;
    padding: 0.5rem 1rem;
    color: #555;
    font-style: italic;
    margin: 0.75rem 0 1rem;
    background: #fafafa;
  }
  .md-content table {
    border-collapse: collapse;
    width: 100%;
    margin: 0.75rem 0 1rem;
    font-size: 0.9rem;
  }
  .md-content th {
    background: #f5f5f5;
    font-weight: 700;
    padding: 0.5rem 0.75rem;
    border: 1px solid #ddd;
    text-align: left;
  }
  .md-content td {
    padding: 0.45rem 0.75rem;
    border: 1px solid #ddd;
    vertical-align: top;
  }
  .md-content tr:nth-child(even) td { background: #fafafa; }
  .md-content input[type="checkbox"] { margin-right: 0.4rem; }
  .md-content a { color: #0070f3; }
  .md-content a:hover { text-decoration: underline; }
</style>
